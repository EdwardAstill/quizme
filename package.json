{
  "name": "quizme",
  "version": "1.0.0",
  "description": "A local quiz app — load a JSON quiz file, take it in your browser, get instant feedback.",
  "type": "module",
  "bin": {
    "quizme": "bin/quizme.js"
  },
  "scripts": {
    "start": "node --import tsx cli.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "echo 'QuizMe installed. Run: quizme <quiz.json>'"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.16.2",
    "vite": "^5.3.4",
    "@vitejs/plugin-react": "^4.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.3"
  }
}
